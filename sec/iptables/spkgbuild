# description	: Linux kernel (2.4+) firewall, NAT and packet mangling tools
# depends	: linux-api-headers flex bison

name=iptables
version=1.8.11
release=1
options="!lto"
source="https://www.netfilter.org/projects/iptables/files/$name-$version.tar.xz
        iptables-service.initd
        rc.iptables iptables.initd iptables.confd ip6tables.confd"
backup="etc/systemd/scripts/iptables"

build() {
	cd $name-$version

    ./configure \
        --prefix=/usr \
        --disable-nftables \
        --enable-libipq
    make
}

package() {
    cd $name-$version

    make DESTDIR="$PKG" install

    install -Dm 700 ../rc.iptables "$PKG"/etc/rc.d/rc.iptables

	install -D -m755 "$SRC"/iptables.initd "$PKG"/etc/init.d/iptables
	install -D -m644 "$SRC"/iptables.confd "$PKG"/etc/conf.d/iptables
	install -D -m755 "$SRC"/iptables.initd "$PKG"/etc/init.d/ip6tables
	install -D -m644 "$SRC"/ip6tables.confd "$PKG"/etc/conf.d/ip6tables

    
    install -D -m755 "$SRC"/iptables-service.initd "$PKG"/etc/systemd/scripts/iptables
}
