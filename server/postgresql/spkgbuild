# description	: PostgreSQL RDBMS
# depends	: less intltool icu pam perl python3 readline openssl tcl 
# depends	: libxml2 zlib zstd util-linux
# optional	: krb5!!openldap

name=postgresql
version=17.5
release=1
source="https://ftp.postgresql.org/pub/source/v$version/$name-$version.tar.bz2
        postgresql.initd postgresql.confd"

build() {
	cd $name-$version

    sed -i '/DEFAULT_PGSOCKET_DIR/s@/tmp@/run/postgresql@' src/include/pg_config_manual.h &&

    ./configure \
        --prefix=/usr \
        --enable-nls \
        --enable-thread-safety \
        --docdir=/usr/share/doc/$name-$version
    make
}

package() {
    cd $name-$version

	make DESTDIR="$PKG" install
    make DESTDIR="$PKG" install-docs

    install -v -dm700 "$PKG"/srv/pgsql/data &&
    install -v -dm755 "$PKG"/run/postgresql &&
    chown -Rv postgres:postgres "$PKG"/srv/pgsql "$PKG"/run/postgresql

	install -Dm755 "$SRC"/postgresql.initd "$PKG"/etc/init.d/postgresql
	install -Dm644 "$SRC"/postgresql.confd "$PKG"/etc/conf.d/postgresql

    sed -e "s|@SLOT@|${version}|g" -e "s|@LIBDIR@|lib|g" -i "$PKG"/etc/conf.d/postgresql
    sed -e "s|@SLOT@|${version}|g" -e "s|@LIBDIR@|lib|g" -i "$PKG"/etc/init.d/postgresql
}
