# description	: Standard log daemons
# depends	: acl openrc

name=sysklogd
version=2.7.0
release=1
source="https://github.com/troglobit/sysklogd/releases/download/v$version/$name-$version.tar.gz
        syslog.conf sysklogd.initd sysklogd.confd"

build() {
    cd $name-$version

    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --runstatedir=/run \
        --without-logger \
        --disable-static \
        --docdir=/usr/share/doc/$name-$version
    make
}

package() {
    cd $name-$version

    make  DESTDIR="$PKG" install
    install -Dm 644 ../syslog.conf  "$PKG"/etc/syslog.conf

	install -D -m755 "$SRC"/sysklogd.initd "$PKG"/etc/init.d/sysklogd
	install -D -m644 "$SRC"/sysklogd.confd "$PKG"/etc/conf.d/sysklogd
}
