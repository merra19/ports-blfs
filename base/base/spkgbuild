name=base
version=20230101
release=1
source="ifconfig.eth0"

package() {
    mkdir -p "$PKG"/etc

    dircolors -p > "$PKG"/etc/dircolors
    clear > "$PKG"/etc/issue

    install -Dm 644 "$SRC"/ifconfig.eth0 "$PKG"/etc/sysconfig/ifconfig.eth0
}
